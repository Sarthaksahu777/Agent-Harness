# .dockerignore — Exclude files from Docker build context

# Git
.git/
.gitignore
.github/

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Docs (not needed in runtime image)
docs/
*.md
!README.md

# Experiments and dashboards (optional)
experiments/
dashboards/

# Local config overrides
*.local.*
.env.local
