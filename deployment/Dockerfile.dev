# Dockerfile.dev — Development container for Agent Harness
# Includes dev dependencies and hot-reload support

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy dependency files
COPY pyproject.toml MANIFEST.in ./

# Install package in editable mode with dev dependencies
RUN pip install --no-cache-dir -e ".[dev,examples]" 2>/dev/null || \
    pip install --no-cache-dir pytest pytest-cov httpx numpy fastapi uvicorn pyyaml

# Copy source code
COPY src/ ./src/
COPY config/ ./config/
COPY tests/ ./tests/
COPY examples/ ./examples/

# Set Python path
ENV PYTHONPATH=/app/src
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Expose port
EXPOSE 8080

# Default: run with hot-reload
CMD ["python", "-m", "uvicorn", "governance.proxy_enforcer:app", "--host", "0.0.0.0", "--port", "8080", "--reload", "--reload-dir", "/app/src"]
